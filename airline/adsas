# List for current reserved seats True if reserved
#fun way to make lists while not typing a bunch
reserved_seats = [False] * 10

def hasMoreFirstClassSeat(seats: list) -> bool:
    return False in seats[0:5]

def hasMoreEconomySeat(seats: list) -> bool:
    return False in seats[5:10]

def assignFirstClassSeat(seats: list) -> int:
    for i in range(0, 5):
        if not seats[i]:
            seats[i] = True
            return i + 1
    return -1

def assignEconomySeat(seats: list) -> int:
    for i in range(5, 10):
        if not seats[i]:
            seats[i] = True
            return i + 1
    return -1

def printBoardingPass(seatNumber: int):
    
    if 1 <= seatNumber <= 5:
        print(f"Seat Number: {seatNumber} First Class")
    elif 6 <= seatNumber <= 10:
        print(f"Seat Number: {seatNumber} Economy Class")
    else:
        print("Error: Invalid seat assignment.")
    

