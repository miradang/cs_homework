def mainDisplay():
    #loop continues as long as there is at least one false in list
    while not all(reserved_seats):
        #get input as a string for data validation
        choice = input("Please type 1 for First Class and 2 for Economy: ").strip()
        
        if choice == '1':
            if hasMoreFirstClassSeat(reserved_seats):
                seat_num = assignFirstClassSeat(reserved_seats)
                printBoardingPass(seat_num)
            else:
                if hasMoreEconomySeat(reserved_seats):
                    response = input("""First Class is full. Is economy seat OK?\n Type "Y" for yes, "N" for no: """).strip().lower()
                    #data validation
                    if response == 'y':
                        seat_num = assignEconomySeat(reserved_seats)
                        printBoardingPass(seat_num)
                    else:
                        print("Next flight leaves in 3 hours.\n")
                else:
                    print("The plane is completely full.\n")
                    
        elif choice == '2':
            if hasMoreEconomySeat(reserved_seats):
                seat_num = assignEconomySeat(reserved_seats)
                printBoardingPass(seat_num)
            else:
                if hasMoreFirstClassSeat(reserved_seats):
                    response = input("""Economy is full. Is First-class seat OK?\n Type "Y" for yes, "N"for no: """).strip().lower()
                    if response == 'y':
                        seat_num = assignFirstClassSeat(reserved_seats)
                        printBoardingPass(seat_num)
                    else:
                        print("Next flight leaves in 3 hours.\n")
                else:
                    print("The plane is completely full.\n")
                    
        else:
            print("Invalid input. Please enter 1 or 2.\n")
            
    print("This flight is fully booked.")
    print("Next flight leaves in 3 hours.")
    
